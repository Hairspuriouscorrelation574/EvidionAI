# ══════════════════════════════════════════════════════════════════════════════
#  EvidionAI — Environment Configuration
#  Copy this file to .env, or run install.sh to generate it interactively.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose ONE of: ollama_local | ollama_cloud | openai
LLM_PROVIDER=ollama_cloud

# Model name — must exist in your chosen provider.
#
# Recommended (tested):
#   ollama_cloud  → glm-5:cloud     best quality (GLM-5 series)
#                   gpt-oss:120b    fast, strong reasoning
#                   gpt-oss:20b     lightweight cloud option
#   ollama_local  → gpt-oss:20b     if you have enough VRAM
#                   deepseek-r1:14b strong reasoning, 8 GB RAM
#                   deepseek-r1:8b  lighter version, 5 GB RAM
#   openai        → gpt-4o, gpt-4o-mini, o3-mini, claude-3-5-sonnet (via proxy)
LLM_MODEL=glm-5:cloud

# Context window in tokens.
# ollama_cloud: up to 128k–197k depending on model
# ollama_local: depends on your RAM (8192–32768 is safe for most setups)
LLM_CTX=32768

# ── Ollama local ──────────────────────────────────────────────────────────────
# Only used when LLM_PROVIDER=ollama_local
OLLAMA_HOST=http://localhost:11434

# ── Ollama Cloud ──────────────────────────────────────────────────────────────
# Only used when LLM_PROVIDER=ollama_cloud
# Sign up at https://ollama.com to get an API key
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=

# ── OpenAI / compatible API ───────────────────────────────────────────────────
# Only used when LLM_PROVIDER=openai
# Works with OpenAI, Groq, Together, Anthropic-compatible proxies, etc.
OPENAI_API_KEY=
# Optional: override base URL for non-OpenAI endpoints
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ── API Gateway ───────────────────────────────────────────────────────────────
AI_AGENTS_HOST=ai_agents_service
AI_AGENTS_PORT=8000
AI_QUERY_MAX_LENGTH=5000
AI_REQUEST_TIMEOUT=14400

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Memory (ChromaDB) ─────────────────────────────────────────────────────────
MEMORY_DIR=/data/memory

# ── Data Storage (SQLite) ─────────────────────────────────────────────────────
DATA_DIR=/data

# ── Worker Threads ────────────────────────────────────────────────────────────
WORKER_THREADS=4

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
